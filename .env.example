# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin day blocking (server only — never expose to the client)
ADMIN_PASSWORD=choose-a-strong-password

# Public app URL (used in edit links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — booking confirmation / update / cancellation emails
# https://resend.com/api-keys — verify your sending domain in Resend first
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=Photoshoot Bookings <bookings@your-verified-domain.com>
# Optional reply-to address (defaults to no reply-to override)
# RESEND_REPLY_TO=studio@your-domain.com
